CSS

body {
    font-family: 'Segoe UI', sans-serif;
}


.nav-link {
    font-weight: bold;
    color: #1f3f44;
    position: relative;
}

.nav-link::after {
    content: "";
    position: absolute;
    width: 0;
    height: 2px;
    background: #1f3f44;
    bottom: -5px;
    left: 0;
    transition: 0.3s;
}

.nav-link:hover::after {
    width: 100%;
}


.btn-main {
    background: #2f6f77;
    color: white;
    padding: 15px 30px;
    border-radius: 50px;
    transition: 0.3s;
}

.btn-main:hover {
    transform: scale(1.05);
}

.btn-active {
    background: #5eaab3;
    color: white;
    padding: 10px;
    border-radius: 10px;
    width: 100%;
}

.btn-inactive {
    background: #e0e8e9;
    color: #1f3f44;
    padding: 10px;
    border-radius: 10px;
    width: 100%;
}

.card-info {
    background: white;
    padding: 30px;
    border-radius: 20px;
    text-align: center;
    transition: 0.3s;
}

.card-info span {
    font-size: 40px;
    display: block;
    margin-bottom: 15px;
}

.card-info h3 {
    font-weight: bold;
    margin-bottom: 10px;
    color: #1f3f44;
}

.card-info p {
    font-size: 14px;
    color: #666;
}

.card-info:hover {
    transform: translateY(-8px);
}


.card-team {
    background: #f9fbfc;
    padding: 20px;
    border-radius: 15px;
    text-align: center;
}

.team-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin: auto;
    object-fit: cover;
    margin-bottom: 10px;
}


JS

document.addEventListener("DOMContentLoaded", () => {

   
    const nav = document.getElementById("main-nav");

    window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
            nav.classList.add("bg-white", "shadow-md", "py-4");
            nav.classList.remove("py-6");
        } else {
            nav.classList.remove("bg-white", "shadow-md", "py-4");
            nav.classList.add("py-6");
        }
    });

    
    document.getElementById("btnExplorar").addEventListener("click", () => {
        document.getElementById("impacto").scrollIntoView({ behavior: "smooth" });
    });

   
    const data = {
        mensal: [4500, 3200, 2100, 1800, 850],
        anual: [54000, 38500, 25200, 21600, 10200]
    };

    
    const ctx = document.getElementById("donationChart");

    const chart = new Chart(ctx, {
        type: "bar",
        data: {
            labels: ["Água", "Alimentos", "Roupas", "Higiene", "Limpeza"],
            datasets: [{
                data: data.mensal
            }]
        }
    });

  
    document.getElementById("btn-mensal").onclick = () => {
        chart.data.datasets[0].data = data.mensal;
        chart.update();
        document.getElementById("total-doacoes").textContent = "12.450";
    };

    document.getElementById("btn-anual").onclick = () => {
        chart.data.datasets[0].data = data.anual;
        chart.update();
        document.getElementById("total-doacoes").textContent = "149.500";
    };

   
    document.getElementById("btnCTA").onclick = () => {
        const msg = document.getElementById("cta-message");
        msg.classList.remove("hidden");

        setTimeout(() => {
            msg.classList.add("hidden");
        }, 3000);
    };

});
